  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordimontano/claudex.git"
  },
  "bugs": {
    "url": "https://github.com/jordimontano/claudex/issues"
  },
  "homepage": "https://github.com/jordimontano/claudex#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
